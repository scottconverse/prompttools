# Normalize line endings to LF on commit, checkout as LF everywhere
* text=auto eol=lf

# Binary files — never touch
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.exe binary
*.zip binary
*.gz binary
*.tar binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pyc binary
*.db binary
*.lock binary
